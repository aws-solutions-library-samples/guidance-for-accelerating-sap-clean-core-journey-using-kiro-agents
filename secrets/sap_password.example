# SAP Password File
#
# This file should contain ONLY your SAP password (no newline at end).
#
# Setup:
#   read -s -p "SAP Password: " SAP_PASS && echo
#   echo -n "$SAP_PASS" > secrets/sap_password
#   chmod 644 secrets/sap_password
#   unset SAP_PASS
#
# The actual sap_password file should be:
# - Plain text, no quotes
# - No trailing newline (use echo -n)
# - Permissions 644 (need read access to others for agent)
#
# Example content (replace with your actual password):
# MySecureP@ssw0rd
