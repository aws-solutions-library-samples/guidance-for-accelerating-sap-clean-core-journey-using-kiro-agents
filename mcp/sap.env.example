# =============================================================================
# SAP Connection Configuration Template
# =============================================================================
# Copy this file to sap.env and fill in your SAP system details:
#   cp sap.env.template sap.env
#
# IMPORTANT: Never commit sap.env to version control (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# SAP System Identification
# -----------------------------------------------------------------------------

# SAP System ID (3 characters, e.g., DEV, QAS, PRD, A4H)
SAP_SID=XXX

# Human-readable description for logs and reports
SAP_DESCRIPTION=Description of your SAP system

# -----------------------------------------------------------------------------
# Connection Parameters
# -----------------------------------------------------------------------------

# SAP host and HTTP port (format: hostname:port or ip:port)
# Example: sap-dev.company.com:8000 or 10.0.1.50:50000
SAP_HOST=hostname:port

# SAP client number (3 digits, e.g., 000, 001, 100)
SAP_CLIENT=000

# SAP username with RFC/ADT authorization
# Required authorizations: S_RFC, S_ADT_RES
SAP_USERNAME=username

# Language for SAP messages (2-char ISO code: EN, DE, ES, etc.)
SAP_LANGUAGE=EN

# Use HTTPS for SAP connection (true/false)
# Set to true if SAP ICM is configured with SSL certificate
SAP_SECURE=true

# -----------------------------------------------------------------------------
# Password Configuration
# -----------------------------------------------------------------------------
# Password is stored separately in /clean-core/secrets/sap_password
# Create it with restricted permissions:
#   echo -n "your_password" > /clean-core/secrets/sap_password
#   chmod 644 /clean-core/secrets/sap_password
# -----------------------------------------------------------------------------
